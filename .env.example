# Copia este archivo como .env y completa tus credenciales.
# Nunca subas .env a GitHub.

# MongoDB Atlas — Connection string (Database > Connect > Drivers)
MONGODB_URI=mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Opcional
# MONGODB_DB=meraki_cobranza
# MONGODB_COLLECTION=bitacora_seguimientos

# Primer administrador (solo si la colección de usuarios está vacía)
ADMIN_USUARIO=admin
ADMIN_NOMBRE=Administrador General
ADMIN_PASSWORD=cambiar_esta_contraseña
