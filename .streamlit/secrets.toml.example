# Copia este contenido en Streamlit Cloud:
#   App → Settings → Secrets
#
# Para desarrollo local, copia este archivo como:
#   .streamlit/secrets.toml
# (ese archivo NO se sube a GitHub)

MONGODB_URI = "mongodb+srv://USUARIO:CONTRASEÑA@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"

# Opcional
# MONGODB_DB = "meraki_cobranza"
# MONGODB_COLLECTION = "bitacora_seguimientos"

# Primer administrador (solo si no hay usuarios en la base)
ADMIN_USUARIO = "admin"
ADMIN_NOMBRE = "Administrador General"
ADMIN_PASSWORD = "cambiar_esta_contraseña"
